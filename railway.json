{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "startCommand": "node server/index.cjs",
    "healthcheckPath": "/",
    "multiRegionConfig": {
      "sfo": {
        "numReplicas": 1
      }
    }
  }
}
